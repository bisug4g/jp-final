{
  "hosting": {
    "public": "firebase-hosting",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "/screenshots/**",
        "headers": [{"key": "Cache-Control", "value": "public, max-age=86400"}]
      }
    ],
    "rewrites": [
      {"source": "**", "destination": "/index.html"}
    ]
  }
}
